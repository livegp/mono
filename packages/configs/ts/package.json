{
  "name": "@mono/ts-config",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "tsconfigs for Mono",
  "license": "MIT",
  "scripts": {
    "check-types": "echo \"No TypeScript files to type-check in @mono/ts-config\"",
    "lint": "bunx ultracite check",
    "lint:fix": "bunx ultracite fix",
    "clean": "rm -rf .turbo dist",
    "reset": "bun --cwd ../../.. run reset"
  },
  "exports": {
    "./base": "./tsconfig.base.json"
  }
}
