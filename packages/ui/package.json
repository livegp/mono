{
  "name": "@mono/ui",
  "version": "0.0.1",
  "license": "MIT",
  "private": true,
  "type": "module",
  "description": "UI components for Mono",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./styles": "./src/styles/globals.css",
    "./components/*": "./src/components/*",
    "./lib/*": "./src/lib/*",
    "./hooks/*": "./src/hooks/*"
  },
  "scripts": {
    "dev": "bunx -b vite",
    "build": "bunx -b vite build",
    "lint": "bunx ultracite check",
    "lint:fix": "bunx ultracite fix",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf .turbo dist",
    "reset": "bun --cwd ../.. run reset"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@mono/ts-config": "workspace:*",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "typescript": "catalog:"
  }
}
