{
  "name": "@mono/config",
  "version": "0.0.1",
  "license": "MIT",
  "private": true,
  "type": "module",
  "description": "shared ts and vite configs for Mono",
  "scripts": {
    "check-types": "echo \"No TypeScript files to type-check in @mono/config\"",
    "lint": "bunx ultracite check",
    "lint:fix": "bunx ultracite fix",
    "clean": "rm -rf .turbo dist"
  },
  "exports": {
    "./ts/strict": "./ts/strict.json",
    "./ts/react-app": "./ts/react-app.json",
    "./ts/react-lib": "./ts/react-lib.json",
    "./ts/backend-bun": "./ts/backend-bun.json",
    "./ts/tooling-bun": "./ts/tooling-bun.json",
    "./vite/base": "./vite/base.ts",
    "./vite/react-app": {
      "types": "./vite/react-app.d.ts",
      "default": "./vite/react-app.ts"
    }
  },
  "peerDependencies": {
    "@vitejs/plugin-react": "^5.1.4",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "browserslist": "^4.28.1",
    "lightningcss": "^1.31.1"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "typescript": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}


