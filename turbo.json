{
  "$schema": "./node_modules/turbo/schema.json",
  "ui": "tui",
  "globalDependencies": ["**/.env.*"],
  "tasks": {
    "dev": {
      "persistent": true,
      "cache": false
    },
    "build": {
      "cache": true,
      "inputs": ["$TURBO_DEFAULT$", "!**/*.test.*", "!**/*.spec.*"],
      "outputs": ["dist/**", "build/**", ".next/**", "storybook-static/**"],
      "dependsOn": ["^build"]
    },
    "check-types": {
      "cache": true,
      "dependsOn": ["^check-types"]
    },
    "clean": {
      "cache": false,
      "dependsOn": ["^clean"]
    },
    "lint": {
      "cache": true,
      "dependsOn": ["^lint"]
    }
  }
}
