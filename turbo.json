{
  "$schema": "./node_modules/turbo/schema.json",
  "ui": "tui",
  "globalDependencies": ["**/.env", "**/.env.*"],
  "globalEnv": ["NODE_ENV"],
  "tasks": {
    "dev": {
      "persistent": true,
      "cache": false
    },
    "build": {
      "cache": true,
      "inputs": ["$TURBO_DEFAULT$", "!**/*.test.*", "!**/*.spec.*"],
      "dependsOn": ["^build"]
    },
    "@mono/backend#build": {
      "cache": true,
      "inputs": ["$TURBO_DEFAULT$", "!**/*.test.*", "!**/*.spec.*"],
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@mono/frontend#build": {
      "cache": true,
      "inputs": ["$TURBO_DEFAULT$", "!**/*.test.*", "!**/*.spec.*"],
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "env": ["VITE_*"]
    },
    "@mono/ui#build": {
      "cache": true,
      "inputs": ["$TURBO_DEFAULT$", "!**/*.test.*", "!**/*.spec.*"],
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "env": ["VITE_*"]
    },
    "@mono/docs#build": {
      "cache": true,
      "inputs": ["$TURBO_DEFAULT$", "!**/*.test.*", "!**/*.spec.*"],
      "dependsOn": ["^build"],
      "outputs": ["storybook-static/**"],
      "env": ["VITE_*"]
    },
    "check-types": {
      "cache": true,
      "dependsOn": ["^check-types"]
    },
    "clean": {
      "cache": false,
      "dependsOn": ["^clean"]
    },
    "lint": {
      "cache": true,
      "dependsOn": ["^lint"]
    },
    "lint:fix": {
      "cache": false,
      "dependsOn": ["^lint:fix"]
    }
  }
}
