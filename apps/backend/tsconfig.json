{
  "extends": "@mono/ts-config/base",
  "compilerOptions": {
    "tsBuildInfoFile": "node_modules/.tmp/tsconfig.tsbuildinfo",
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "build", ".turbo"]
}
