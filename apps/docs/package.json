    "@storybook/react-vite": "^10.2.13",
    "@storybook/test": "^8.6.15",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "^5.1.4",
    "globals": "^17.3.0",
    "storybook": "^10.2.13",
