{
  "extends": "@mono/config/ts/react-app",
  "compilerOptions": {
    "tsBuildInfoFile": "node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@mono/ui/*": ["../../packages/ui/src/*"]
